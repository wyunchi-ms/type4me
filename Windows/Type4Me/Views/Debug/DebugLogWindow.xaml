<Window x:Class="Type4Me.Views.Debug.DebugLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Type4Me — Debug Console"
        Width="800" Height="520"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Override text styles for dark theme -->
        <Style x:Key="DebugTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#2D2D2D" Padding="8,6">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <CheckBox x:Name="AutoScrollCheck" Content="Auto-scroll"
                              Foreground="#D4D4D4" FontSize="12" Margin="0,0,12,0"
                              IsChecked="True" VerticalAlignment="Center"/>
                    <Button x:Name="ClearBtn" Content="Clear" Click="Clear_Click"
                            Background="#3C3C3C" Foreground="#D4D4D4" FontSize="12"
                            Padding="12,4" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#505050"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <TextBlock Text="🔍 Debug Console" Foreground="#D4D4D4" FontSize="13"
                           FontWeight="SemiBold" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Log entries -->
        <ListView x:Name="LogListView" Background="Transparent" BorderThickness="0"
                  ItemsSource="{Binding Entries}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,3" BorderBrush="#333333" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <!-- Timestamp -->
                            <TextBlock Text="{Binding TimeString}" Foreground="#6A9955"
                                       FontFamily="Cascadia Code, Consolas, monospace"
                                       FontSize="11" Width="85" DockPanel.Dock="Left"
                                       VerticalAlignment="Top"/>

                            <!-- Category tag -->
                            <Border DockPanel.Dock="Left" CornerRadius="3" Padding="5,1"
                                    Margin="0,0,8,0" VerticalAlignment="Top"
                                    Background="#333333">
                                <TextBlock Text="{Binding Category}"
                                           Foreground="{Binding CategoryColor}"
                                           FontFamily="Cascadia Code, Consolas, monospace"
                                           FontSize="10" FontWeight="SemiBold"/>
                            </Border>

                            <!-- Message + Detail -->
                            <StackPanel>
                                <TextBlock Text="{Binding Message}" Foreground="#D4D4D4"
                                           FontFamily="Cascadia Code, Consolas, monospace"
                                           FontSize="12" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Detail}" Foreground="#808080"
                                           FontFamily="Cascadia Code, Consolas, monospace"
                                           FontSize="11" TextWrapping="Wrap"
                                           Margin="0,2,0,0"
                                           Visibility="{Binding Detail, Converter={StaticResource NullToVis}}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </DockPanel>
</Window>
