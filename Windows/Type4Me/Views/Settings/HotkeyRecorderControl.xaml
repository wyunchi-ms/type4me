<UserControl x:Class="Type4Me.Views.Settings.HotkeyRecorderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True">

    <Border x:Name="RecorderBorder" Background="#FDFAF6" CornerRadius="6"
            Padding="12,8" Cursor="Hand" MinWidth="200" HorizontalAlignment="Left"
            BorderBrush="#E8E3D9" BorderThickness="1"
            MouseLeftButtonDown="Border_Click">
        <DockPanel>
            <Button DockPanel.Dock="Right" Content="×" FontSize="12"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#CC4738" Cursor="Hand" Margin="8,0,0,0"
                    Click="Clear_Click" x:Name="ClearBtn" Visibility="Collapsed"/>
            <TextBlock x:Name="DisplayText" FontSize="12" Foreground="#1A1A1A"
                       VerticalAlignment="Center"/>
        </DockPanel>
    </Border>
</UserControl>
