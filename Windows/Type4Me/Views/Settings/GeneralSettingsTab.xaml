<UserControl x:Class="Type4Me.Views.Settings.GeneralSettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Type4Me.Views.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>

        <!-- Card style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#FAF5ED"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Label style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#3D3D3D"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Save button style -->
        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,8,0">
            <!-- ASR Provider -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" x:Name="ASRTitle"/>

                    <TextBlock Style="{StaticResource FieldLabel}" x:Name="ASRProviderLabel"/>
                    <ComboBox x:Name="ASRProviderCombo" Margin="0,0,0,12"
                              SelectionChanged="ASRProviderCombo_SelectionChanged"/>

                    <ItemsControl x:Name="ASRFieldsPanel"/>

                    <Button Style="{StaticResource SaveBtn}" x:Name="SaveASRBtn"
                            Margin="0,8,0,0" HorizontalAlignment="Left"
                            Click="SaveASR_Click"/>
                </StackPanel>
            </Border>

            <!-- LLM Provider -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" x:Name="LLMTitle"/>

                    <TextBlock Style="{StaticResource FieldLabel}" x:Name="LLMProviderLabel"/>
                    <ComboBox x:Name="LLMProviderCombo" Margin="0,0,0,12"
                              SelectionChanged="LLMProviderCombo_SelectionChanged"/>

                    <ItemsControl x:Name="LLMFieldsPanel"/>

                    <Button Style="{StaticResource SaveBtn}" x:Name="SaveLLMBtn"
                            Margin="0,8,0,0" HorizontalAlignment="Left"
                            Click="SaveLLM_Click"/>
                </StackPanel>
            </Border>

            <!-- Preferences -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" x:Name="PrefsTitle"/>

                    <CheckBox x:Name="EnableSoundCheck" Margin="0,0,0,8"
                              Checked="EnableSound_Changed" Unchecked="EnableSound_Changed"/>
                    <CheckBox x:Name="LaunchAtLoginCheck" Margin="0,0,0,8"
                              Checked="LaunchAtLogin_Changed" Unchecked="LaunchAtLogin_Changed"/>

                    <TextBlock Style="{StaticResource FieldLabel}" x:Name="LanguageLabel"/>
                    <ComboBox x:Name="LanguageCombo" Margin="0,0,0,4" Width="180"
                              HorizontalAlignment="Left"
                              SelectionChanged="LanguageCombo_SelectionChanged"/>
                </StackPanel>
            </Border>

            <!-- Status -->
            <TextBlock x:Name="StatusText" FontSize="12" Foreground="#4D9E59" Margin="0,4,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
