<UserControl x:Class="Type4Me.Views.Settings.AboutTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#FAF5ED"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">

        <!-- App Icon & Name -->
        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
            <Border Width="64" Height="64" CornerRadius="12" Background="#D4913D"
                    HorizontalAlignment="Center" Margin="0,0,0,12">
                <TextBlock Text="T4M" FontSize="20" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Type4Me" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="TaglineText" FontSize="12" Foreground="#6B6B6B"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Info Card -->
        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Version -->
                <TextBlock Grid.Row="0" Grid.Column="0" x:Name="VersionLabel"
                           FontSize="12" Foreground="#6B6B6B" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="VersionValue"
                           FontSize="12" Foreground="#1A1A1A" Margin="0,0,0,8"/>

                <!-- Platform -->
                <TextBlock Grid.Row="1" Grid.Column="0" x:Name="PlatformLabel"
                           FontSize="12" Foreground="#6B6B6B" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PlatformValue"
                           FontSize="12" Foreground="#1A1A1A" Margin="0,0,0,8"/>

                <!-- Engine -->
                <TextBlock Grid.Row="2" Grid.Column="0" x:Name="EngineLabel"
                           FontSize="12" Foreground="#6B6B6B" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="EngineValue"
                           FontSize="12" Foreground="#1A1A1A" Margin="0,0,0,8"/>

                <!-- Data Path -->
                <TextBlock Grid.Row="3" Grid.Column="0" x:Name="DataPathLabel"
                           FontSize="12" Foreground="#6B6B6B" Margin="0,0,0,0"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DataPathValue"
                           FontSize="11" Foreground="#1A1A1A" TextWrapping="Wrap"
                           Cursor="Hand" TextDecorations="Underline"
                           MouseLeftButtonDown="DataPath_Click"/>
            </Grid>
        </Border>

        <!-- Open Data Folder Button -->
        <Button x:Name="OpenFolderBtn" HorizontalAlignment="Center"
                Background="#1A1A1A" Foreground="White" FontSize="12"
                Padding="16,8" Cursor="Hand" BorderThickness="0"
                Click="OpenFolder_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </StackPanel>
</UserControl>
