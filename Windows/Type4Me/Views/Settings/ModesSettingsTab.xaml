<UserControl x:Class="Type4Me.Views.Settings.ModesSettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Type4Me.Views.Settings"
             xmlns:conv="clr-namespace:Type4Me.Views.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#FAF5ED"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Mode list -->
        <Border Grid.Column="0" Background="#FAF5ED" CornerRadius="10" Padding="8" Margin="0,0,12,0">
            <DockPanel>
                <Button DockPanel.Dock="Bottom" Style="{StaticResource SmallBtn}"
                        x:Name="AddModeBtn" Margin="0,8,0,0"
                        Click="AddMode_Click"/>

                <ListBox x:Name="ModeListBox" Background="Transparent" BorderThickness="0"
                         SelectionChanged="ModeListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="×" FontSize="12"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="#CC4738" Cursor="Hand"
                                        Click="DeleteMode_Click" Tag="{Binding}"
                                        Visibility="{Binding IsBuiltin, Converter={StaticResource BoolVis}, ConverterParameter=Invert}"/>
                                <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Mode editor -->
        <Border Grid.Column="1" Background="#FAF5ED" CornerRadius="10" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="EditorPanel" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource SectionTitle}" x:Name="EditTitle"/>

                    <!-- Name -->
                    <TextBlock x:Name="NameLabel" FontSize="12" Foreground="#3D3D3D" Margin="0,0,0,4"/>
                    <TextBox x:Name="ModeNameBox" FontSize="12" Margin="0,0,0,12"
                             TextChanged="ModeName_Changed"/>

                    <!-- Hotkey -->
                    <TextBlock x:Name="HotkeyLabel" FontSize="12" Foreground="#3D3D3D" Margin="0,0,0,4"/>
                    <local:HotkeyRecorderControl x:Name="HotkeyRecorder" Margin="0,0,0,12"
                                                  HotkeyChanged="HotkeyRecorder_Changed"/>

                    <!-- Hotkey Style -->
                    <TextBlock x:Name="StyleLabel" FontSize="12" Foreground="#3D3D3D" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <RadioButton x:Name="StyleToggle" GroupName="HotkeyStyle" Margin="0,0,16,0"
                                     Checked="HotkeyStyle_Changed"/>
                        <RadioButton x:Name="StyleHold" GroupName="HotkeyStyle"
                                     Checked="HotkeyStyle_Changed"/>
                    </StackPanel>

                    <!-- Prompt -->
                    <TextBlock x:Name="PromptLabel" FontSize="12" Foreground="#3D3D3D" Margin="0,0,0,4"/>
                    <TextBlock x:Name="PromptDesc" FontSize="11" Foreground="#6B6B6B"
                               Margin="0,0,0,4" TextWrapping="Wrap"/>
                    <TextBox x:Name="PromptBox" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="150" VerticalScrollBarVisibility="Auto"
                             FontSize="12"
                             TextChanged="Prompt_Changed"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
