<Window x:Class="Type4Me.Views.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Type4Me.Views.Settings"
        xmlns:conv="clr-namespace:Type4Me.Views.Converters"
        Title="Type4Me" Width="780" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#F2EBE0">

    <Window.Resources>
        <conv:EqualityConverter x:Key="EqualityConverter"/>

        <!-- Sidebar button style -->
        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="12,8" CornerRadius="6" Cursor="Hand"
                                Background="Transparent">
                            <TextBlock x:Name="Txt" Text="{TemplateBinding Content}"
                                       FontSize="13" Foreground="#6B6B6B"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1A1A"/>
                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                <Setter TargetName="Txt" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#E8E3D9"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#EDE7DD" Padding="12,24,12,12">
            <StackPanel>
                <TextBlock Text="Type4Me" FontSize="18" FontWeight="Bold" Foreground="#1A1A1A"
                           Margin="12,0,0,20"/>

                <RadioButton x:Name="NavGeneral" GroupName="Nav" Style="{StaticResource NavButton}"
                             Content="{Binding GeneralTabLabel}" IsChecked="True"
                             Checked="NavGeneral_Checked"/>
                <RadioButton x:Name="NavVocabulary" GroupName="Nav" Style="{StaticResource NavButton}"
                             Content="{Binding VocabularyTabLabel}" Margin="0,2,0,0"
                             Checked="NavVocabulary_Checked"/>
                <RadioButton x:Name="NavModes" GroupName="Nav" Style="{StaticResource NavButton}"
                             Content="{Binding ModesTabLabel}" Margin="0,2,0,0"
                             Checked="NavModes_Checked"/>
                <RadioButton x:Name="NavHistory" GroupName="Nav" Style="{StaticResource NavButton}"
                             Content="{Binding HistoryTabLabel}" Margin="0,2,0,0"
                             Checked="NavHistory_Checked"/>
                <RadioButton x:Name="NavAbout" GroupName="Nav" Style="{StaticResource NavButton}"
                             Content="{Binding AboutTabLabel}" Margin="0,2,0,0"
                             Checked="NavAbout_Checked"/>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Border Grid.Column="1" Background="#FAF5ED" Padding="24">
            <Grid>
                <local:GeneralSettingsTab x:Name="TabGeneral"/>
                <local:VocabularyTab x:Name="TabVocabulary" Visibility="Collapsed"/>
                <local:ModesSettingsTab x:Name="TabModes" Visibility="Collapsed"/>
                <local:HistoryTab x:Name="TabHistory" Visibility="Collapsed"/>
                <local:AboutTab x:Name="TabAbout" Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Window>
