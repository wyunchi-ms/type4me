<UserControl x:Class="Type4Me.Views.Settings.HistoryTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#FAF5ED"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background" Value="#CC4738"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E05545"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#1A1A1A"
                       VerticalAlignment="Center" x:Name="HistoryTitle"/>
            <TextBlock x:Name="CountLabel" FontSize="12" Foreground="#6B6B6B"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Style="{StaticResource DangerBtn}" x:Name="DeleteAllBtn"
                        Click="DeleteAll_Click" Margin="0,0,8,0"/>
            </StackPanel>
        </DockPanel>

        <!-- Search -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Style="{StaticResource SmallBtn}"
                    x:Name="SearchBtn" Click="Search_Click" Margin="8,0,0,0"/>
            <TextBox x:Name="SearchBox" FontSize="12"
                     KeyDown="SearchBox_KeyDown"/>
        </DockPanel>

        <!-- Records list -->
        <Border Background="#FAF5ED" CornerRadius="10" Padding="8">
            <DockPanel>
                <Button DockPanel.Dock="Bottom" Style="{StaticResource SmallBtn}"
                        x:Name="LoadMoreBtn" Margin="0,8,0,0"
                        HorizontalAlignment="Center" Click="LoadMore_Click"/>

                <ListView x:Name="RecordsListView" Background="Transparent" BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FDFAF6" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="×" FontSize="14"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#CC4738" Cursor="Hand"
                                            VerticalAlignment="Top" Margin="8,0,0,0"
                                            Click="DeleteRecord_Click" Tag="{Binding}"/>

                                    <StackPanel>
                                        <TextBlock Text="{Binding FinalText}" FontSize="12"
                                                   Foreground="#1A1A1A" TextWrapping="Wrap"
                                                   MaxHeight="60" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                       FontSize="10" Foreground="#6B6B6B"/>
                                            <TextBlock FontSize="10" Foreground="#6B6B6B" Margin="8,0,0,0"
                                                       Text="{Binding ProcessingMode}"/>
                                            <TextBlock FontSize="10" Foreground="#6B6B6B" Margin="8,0,0,0"
                                                       Text="{Binding DurationSeconds, StringFormat='{}{0:F1}s'}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>
        </Border>
    </DockPanel>
</UserControl>
