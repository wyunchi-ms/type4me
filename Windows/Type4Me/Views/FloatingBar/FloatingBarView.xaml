<UserControl x:Class="Type4Me.Views.FloatingBar.FloatingBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="420" d:DesignHeight="52">
    <Grid>
        <!-- Capsule background -->
        <Border x:Name="CapsuleBorder"
                CornerRadius="26"
                Height="52"
                HorizontalAlignment="Center"
                MinWidth="200" MaxWidth="400"
                Padding="16,0">
            <Border.Background>
                <SolidColorBrush Color="#E8202020"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Status indicator dot -->
                <Ellipse x:Name="StatusDot"
                         Grid.Column="0"
                         Width="10" Height="10"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0"/>

                <!-- Text content -->
                <TextBlock x:Name="ContentText"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="340"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
