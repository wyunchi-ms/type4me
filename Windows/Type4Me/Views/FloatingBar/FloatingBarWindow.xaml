<Window x:Class="Type4Me.Views.FloatingBar.FloatingBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Type4Me"
        Width="420" Height="60"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid>
        <local:FloatingBarView x:Name="BarView"
                               xmlns:local="clr-namespace:Type4Me.Views.FloatingBar"/>
    </Grid>
</Window>
