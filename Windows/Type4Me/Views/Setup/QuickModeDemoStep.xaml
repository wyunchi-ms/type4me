<UserControl x:Class="Type4Me.Views.Setup.QuickModeDemoStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock x:Name="TitleText" FontSize="20" FontWeight="Bold"
                   Foreground="#1A1A1A" HorizontalAlignment="Center"
                   Margin="0,0,0,8"/>
        <TextBlock x:Name="DescText" FontSize="12" Foreground="#6B6B6B"
                   HorizontalAlignment="Center" TextWrapping="Wrap"
                   TextAlignment="Center" MaxWidth="400" Margin="0,0,0,24"/>

        <!-- Simulated desktop area -->
        <Border Background="#2D2D2D" CornerRadius="10" Width="440" Height="200"
                ClipToBounds="True">
            <Grid>
                <!-- Floating bar simulation at bottom center -->
                <Border x:Name="DemoBar" Background="#1A1A1A" CornerRadius="20"
                        Height="44" Width="300"
                        VerticalAlignment="Bottom" HorizontalAlignment="Center"
                        Margin="0,0,0,16" Opacity="0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8"
                                 Fill="#D4913D" Margin="0,0,8,0"/>
                        <TextBlock x:Name="DemoText" FontSize="12" Foreground="White"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
